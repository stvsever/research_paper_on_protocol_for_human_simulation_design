# Keep source notes, gitkeeps, and small reference CSVs
!data/raw/**/SOURCE.md
!data/raw/**/README.md
!data/raw/**/*.md
!data/raw/model_benchmarks/mmlu_pilot_model_mapping.csv

# Generated / processed data (not versioned)
data/interim/*
data/processed/*
!data/interim/.gitkeep
!data/processed/.gitkeep
